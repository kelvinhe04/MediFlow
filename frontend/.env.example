# ------------------------------------------------------------------
# MediFlow — Frontend environment variables
# Solo variables PÚBLICAS (prefijo VITE_*). Se exponen al navegador.
# NUNCA poner aquí secretos del backend (MONGODB_URI, STRIPE_SECRET_KEY, etc.).
# ------------------------------------------------------------------

# URL base del backend (vacío = usar el proxy /api de Vite en dev)
VITE_API_BASE_URL=

# Clerk — solo la publishable key (pública por diseño)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe — solo la publishable key (pública por diseño)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
