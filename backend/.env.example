# ------------------------------------------------------------------
# MediFlow — Backend environment variables
# Copiar este archivo como `.env` y completar con valores reales.
# NUNCA subir el `.env` real al repositorio.
# ------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=3000

# CORS — origen del frontend (sin slash final)
FRONTEND_ORIGIN=http://localhost:5173

# MongoDB Atlas
# Formato: mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB_NAME=mediflow

# Clerk (auth)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Stripe (sandbox)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
